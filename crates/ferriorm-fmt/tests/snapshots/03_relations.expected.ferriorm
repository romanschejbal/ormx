datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       String @id @default(uuid())
  posts    Post[]
  authored Post[] @relation("Authored")
  edited   Post[] @relation("Edited")
}

model Post {
  id       String  @id @default(uuid())
  title    String
  content  String?
  author   User    @relation("Authored", fields: [authorId], references: [id], onDelete: Cascade)
  authorId String
  editor   User    @relation("Edited", fields: [editorId], references: [id])
  editorId String

  @@index([authorId, title], name: "post_author_title_idx")
  @@unique([authorId, title])
}
